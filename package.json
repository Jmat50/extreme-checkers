{
  "name": "extreme-checkers",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "server": "tsx server/index.ts",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\"",
    "convert-models": "tsx scripts/convert-models.ts",
    "build:gh": "cross-env BASE_PATH=/extreme-checkers/ npm run build",
    "verify:gh": "node scripts/verify-gh-pages.mjs",
    "test:gh": "npm run build:gh && npm run verify:gh"
  },
  "dependencies": {
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.16.3",
    "boardgame.io": "^0.50.2",
    "koa": "^2.15.3",
    "koa-body": "^8.0.0",
    "node-persist": "^4.0.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io-client": "^4.8.1",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.1"
  }
}
